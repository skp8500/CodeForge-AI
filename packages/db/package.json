{
  "name": "@codeforge/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@codeforge/shared": "workspace:*",
    "drizzle-orm": "^0.31.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@codeforge/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^2.4.3",
    "drizzle-kit": "^0.22.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
