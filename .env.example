# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/codeforge

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# ─── OAuth ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=codeforge-assets
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# ─── SMTP (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@codeforge.dev

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL of the Next.js app — used for OAuth redirects and email verification links
FRONTEND_URL=http://localhost:3000

# ─── Frontend (public — exposed to browser) ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
