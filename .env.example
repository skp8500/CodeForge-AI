# Infrastructure
DATABASE_URL=postgresql://codeforge:devpassword@localhost:5432/codeforge
REDIS_URL=redis://localhost:6379

# JWT — generate real secrets before using in production
JWT_ACCESS_SECRET=dev_access_secret_change_in_production_min_64_chars_abcdefgh
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_min_64_chars_12345678
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
EMAIL_VERIFICATION_SECRET=dev_email_secret_change_in_production_abcdefgh12345678

# Google OAuth — get from console.cloud.google.com
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# GitHub OAuth — get from github.com/settings/developers
GITHUB_CLIENT_ID=REPLACE_ME
GITHUB_CLIENT_SECRET=REPLACE_ME
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# OpenAI — get from platform.openai.com/api-keys
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gpt-4o

# Email (Mailtrap for local dev — free at mailtrap.io)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
SMTP_FROM=noreply@codeforge.local

# AWS S3 (optional for local dev — file uploads won't work without it)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_S3_BUCKET=codeforge-assets-dev
AWS_CLOUDFRONT_URL=

# API Server
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
APP_VERSION=0.1.0
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:3000
SECURE_COOKIES=false
INTERNAL_SERVICE_SECRET=dev_internal_secret_12345

# Docker (Judge Worker)
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_REGISTRY=
JUDGE_DEFAULT_TIME_LIMIT_MS=2000
JUDGE_DEFAULT_MEMORY_LIMIT_MB=256
JUDGE_MAX_OUTPUT_SIZE_MB=64
JUDGE_CONTAINER_PID_LIMIT=64
QUEUE_CONCURRENCY=2
QUEUE_MAX_RETRIES=3

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_NAME=CodeForge AI
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rate Limits
RATE_LIMIT_GLOBAL_RPM=200
RATE_LIMIT_SUBMISSIONS_PER_HOUR=60
RATE_LIMIT_AI_RPM=10
RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_REGISTER_PER_MIN=3
RATE_LIMIT_MAX_PENDING_SUBMISSIONS=5

# Feature Flags
FEATURE_AI_REVIEW=true
FEATURE_AI_EXPLAIN=true
FEATURE_PER_TEST_RESULTS=true
FEATURE_ORGS=true
FEATURE_CONTESTS=false
FEATURE_RATINGS=false
FEATURE_PLAGIARISM=false

# Monitoring (skipped for now — leave blank)
SLACK_WEBHOOK_URL=
SENTRY_DSN=
LOG_LEVEL=info
